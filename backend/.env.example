APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

# JWT Authentication Secret (REQUIRED)
# Generate with: php artisan jwt:secret
# Or set manually (64 characters recommended)
JWT_SECRET=

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Mailer (ResendService uses MailerSend API directly — Laravel Mail is unused)
# Keep MAIL_MAILER=log unless you need SMTP for something else
MAIL_MAILER=log

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# MailerSend API — All production emails go through this
# Get your key at https://www.mailersend.com
MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=

# Admin email to receive contact/lead/login notifications
MAIL_ADMIN_EMAIL=mrmhmdalshhatly@gmail.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# AI provider API keys
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
TOGETHER_API_KEY=

# Image hosting (ImgBB) — get a free key at https://api.imgbb.com/
# Or add keys via admin API Keys page with provider "imgbb"
IMGBB_API_KEY=
